# IPFS — Pinata (https://app.pinata.cloud)
PINATA_API_KEY=
PINATA_SECRET_KEY=

# Stellar network: "testnet" or "public"
NEXT_PUBLIC_STELLAR_NETWORK=testnet

# Stellar NFT issuer secret key (the account that issues observation NFTs)
# Generate a keypair at https://laboratory.stellar.org/#account-creator
STELLAR_ISSUER_SECRET=
